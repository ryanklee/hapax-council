{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://hapax.local/schemas/metadata.schema.json",
  "title": "METADATA.yaml Schema",
  "description": "Validates METADATA.yaml files describing self-contained agent packages",
  "type": "object",
  "required": ["module", "purpose", "version", "interface", "dependencies", "execution", "token_budget"],
  "additionalProperties": false,
  "properties": {
    "module": {
      "type": "string",
      "minLength": 1,
      "description": "Module identifier (e.g. drift_detector)"
    },
    "purpose": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Human-readable description of the module's purpose"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version, integer starting at 1"
    },
    "interface": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "type": {"type": "string", "minLength": 1},
              "description": {"type": "string"}
            }
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "type": {"type": "string", "minLength": 1},
              "description": {"type": "string"}
            }
          }
        },
        "side_effects": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["target", "operation"],
            "additionalProperties": false,
            "properties": {
              "target": {"type": "string", "minLength": 1},
              "collection": {"type": "string"},
              "operation": {
                "type": "string",
                "enum": ["read", "write", "upsert", "delete"]
              },
              "description": {"type": "string"}
            }
          }
        },
        "props": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "type"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "type": {"type": "string", "minLength": 1},
              "description": {"type": "string"},
              "required": {"type": "boolean"}
            }
          }
        },
        "emits": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["event"],
            "additionalProperties": false,
            "properties": {
              "event": {"type": "string", "minLength": 1},
              "payload": {"type": "string"},
              "description": {"type": "string"}
            }
          }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "required": ["internal"],
      "additionalProperties": false,
      "properties": {
        "runtime": {
          "type": "array",
          "items": {"type": "string"},
          "description": "External PyPI package dependencies"
        },
        "internal": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Internal module dependencies — must be empty for self-contained packages"
        },
        "optional": {
          "type": "array",
          "items": {"type": "string"},
          "description": "Optional external dependencies"
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entry": {
          "type": "string",
          "description": "Entry point command (e.g. uv run python -m agents.drift_detector)"
        },
        "flags": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string"},
              "description": {"type": "string"},
              "default": {}
            }
          }
        },
        "environment": {
          "type": "object",
          "additionalProperties": {"type": "string"}
        }
      }
    },
    "token_budget": {
      "type": "object",
      "required": ["self"],
      "additionalProperties": false,
      "properties": {
        "self": {
          "type": "integer",
          "minimum": 0,
          "description": "Token estimate for this module's own source files"
        },
        "with_imports": {
          "type": "integer",
          "minimum": 0,
          "description": "Token estimate including all transitive imports"
        },
        "note": {
          "type": "string",
          "description": "Free-text note about the budget estimate"
        }
      }
    }
  }
}
