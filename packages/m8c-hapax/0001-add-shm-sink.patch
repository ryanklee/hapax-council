From: hapax beta <noreply@anthropic.com>
Subject: [PATCH] add SHM RGBA bridge for re-splay ward

Adds three optional integration points wrapped in `#ifdef USE_SHM_SINK`
that publish every rendered frame to `/dev/shm/hapax-sources/m8-display.rgba`
+ a sidecar `m8-display.rgba.json` with frame-id and dimensions, matching
the studio compositor's external_rgba source pattern (same shape as
Reverie).

The new shm_sink.{c,h} files (shipped alongside this patch) carry the
logic; this patch wires render.c and the Makefile to call them.

When USE_SHM_SINK is not defined the patch compiles into stubs and the
binary behaves identically to upstream — keeping the carry-fork surface
small + trivially rebasable.

cc-task: re-splay-homage-ward-m8 (hapax-council)
---
 Makefile     |  4 ++++
 src/render.c | 12 ++++++++++++
 2 files changed, 16 insertions(+)

diff --git a/Makefile b/Makefile
index 0000000..0000000 100644
--- a/Makefile
+++ b/Makefile
@@ -34,6 +34,10 @@ libusb: INCLUDES = $(shell pkg-config --libs sdl3 libusb-1.0)
 libusb: local_CFLAGS = $(CFLAGS) $(shell pkg-config --cflags sdl3 libusb-1.0) -Wall -Wextra -O2 -pipe -I. -DUSE_LIBUSB=1 -DNDEBUG
 libusb: m8c

+shm: INCLUDES = $(shell pkg-config --libs sdl3 libserialport | sed 's/-mwindows//')
+shm: local_CFLAGS = $(CFLAGS) $(shell pkg-config --cflags sdl3 libserialport) -DUSE_LIBSERIALPORT -DUSE_SHM_SINK -Wall -Wextra -O2 -pipe -I. -DNDEBUG
+shm: m8c
+
 rtmidi: INCLUDES = $(shell pkg-config --libs sdl3 rtmidi)
 rtmidi: local_CFLAGS = $(CFLAGS) $(shell pkg-config --cflags sdl3 rtmidi) -Wall -Wextra -O2 -pipe -I. -DUSE_RTMIDI -DNDEBUG
 rtmidi: m8c
diff --git a/src/render.c b/src/render.c
index 0000000..0000000 100644
--- a/src/render.c
+++ b/src/render.c
@@ -13,6 +13,7 @@
 #include "settings.h"

 #include "fonts/fonts.h"
+#include "shm_sink.h"

 #include <stdlib.h>

@@ -244,6 +245,7 @@ void renderer_close(void) {
   if (hd_texture != NULL) {
     SDL_DestroyTexture(hd_texture);
   }
+  shm_sink_shutdown();
   log_overlay_destroy();
   SDL_DestroyRenderer(rend);
   SDL_DestroyWindow(win);
@@ -474,6 +476,8 @@ int renderer_initialize(config_params_s *conf) {
   renderer_fix_texture_scaling_after_window_resize(
       conf); // iOS needs this, doesn't hurt on others either

+  shm_sink_init();
+
   dirty = 1;

   SDL_PumpEvents();
@@ -568,6 +572,7 @@ void render_screen(config_params_s *conf) {
   if (!SDL_RenderPresent(rend)) {
     SDL_LogCritical(SDL_LOG_CATEGORY_RENDER, "Couldn't present renderer: %s", SDL_GetError());
   }
+  shm_sink_publish(rend, main_texture);

   if (!SDL_SetRenderTarget(rend, main_texture)) {
     SDL_LogCritical(SDL_LOG_CATEGORY_RENDER, "Couldn't set renderer target to texture: %s",
