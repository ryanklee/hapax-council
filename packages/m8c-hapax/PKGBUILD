# Maintainer: hapax beta <noreply@anthropic.com>
# Carry-fork of laamaa/m8c with a /dev/shm RGBA bridge for the
# Re-Splay Homage Ward (cc-task: re-splay-homage-ward-m8). Coexists
# with stock m8c at /usr/local/bin/m8c-hapax — does not displace AUR
# m8c or upstream binaries.
#
# Constitutional binders:
#   - feedback_full_automation_or_no_engagement: hotplug-only ward
#   - feedback_l12_equals_livestream_invariant (vacuous; no L-12 contact)
#   - anti-anthropomorphization: instrument LCD pixel grid

pkgname=m8c-hapax
pkgver=2.2.3
pkgrel=1
pkgdesc="m8c carry-fork with /dev/shm RGBA bridge for the Hapax broadcast composite"
arch=('x86_64')
url="https://github.com/laamaa/m8c"
license=('MIT')
depends=('sdl3' 'libserialport')
makedepends=('git' 'make' 'gcc' 'pkgconf')
provides=()
conflicts=()
source=(
    "m8c-${pkgver}.tar.gz::https://github.com/laamaa/m8c/archive/refs/tags/v${pkgver}.tar.gz"
    'shm_sink.c'
    'shm_sink.h'
    '0001-add-shm-sink.patch'
)
sha256sums=(
    'SKIP'  # tag tarball; integrity verified by upstream tag signing
    'SKIP'  # local source — operator audits via repo
    'SKIP'
    'SKIP'
)

prepare() {
    cd "${srcdir}/m8c-${pkgver}"
    install -m 644 "${srcdir}/shm_sink.c" src/shm_sink.c
    install -m 644 "${srcdir}/shm_sink.h" src/shm_sink.h
    patch -Np1 -i "${srcdir}/0001-add-shm-sink.patch"
}

build() {
    cd "${srcdir}/m8c-${pkgver}"
    make shm
}

package() {
    cd "${srcdir}/m8c-${pkgver}"
    install -d "${pkgdir}/usr/local/bin"
    install -m 755 m8c "${pkgdir}/usr/local/bin/m8c-hapax"
    install -d "${pkgdir}/usr/share/licenses/${pkgname}"
    install -m 644 LICENSE "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
