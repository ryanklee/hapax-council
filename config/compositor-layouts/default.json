{
  "name": "default",
  "description": "Default studio compositor layout — post-epic operator defaults. Reverie upper-right, Vitruvian Man (token_pole) upper-left, album lower-left, chat stats (stream_overlay) lower-right. These assignments are a starting point; Hapax content programming ultimately drives which sources feed which quadrants via the affordance pipeline + command registry.",
  "sources": [
    {
      "id": "token_pole",
      "kind": "cairo",
      "backend": "cairo",
      "params": {"class_name": "TokenPoleCairoSource", "natural_w": 300, "natural_h": 300}
    },
    {
      "id": "album",
      "kind": "cairo",
      "backend": "cairo",
      "params": {"class_name": "AlbumOverlayCairoSource", "natural_w": 400, "natural_h": 520}
    },
    {
      "id": "stream_overlay",
      "kind": "cairo",
      "backend": "cairo",
      "params": {"class_name": "StreamOverlayCairoSource", "natural_w": 400, "natural_h": 200}
    },
    {
      "id": "sierpinski",
      "kind": "cairo",
      "backend": "cairo",
      "params": {"class_name": "SierpinskiCairoSource", "natural_w": 640, "natural_h": 640}
    },
    {
      "id": "reverie",
      "kind": "external_rgba",
      "backend": "shm_rgba",
      "params": {
        "natural_w": 640,
        "natural_h": 360,
        "shm_path": "/dev/shm/hapax-sources/reverie.rgba"
      }
    }
  ],
  "surfaces": [
    {"id": "pip-ul", "geometry": {"kind": "rect", "x":   20, "y":   20, "w": 300, "h": 300}, "z_order": 10},
    {"id": "pip-ur", "geometry": {"kind": "rect", "x": 1260, "y":   20, "w": 640, "h": 360}, "z_order": 10},
    {"id": "pip-ll", "geometry": {"kind": "rect", "x":   20, "y":  540, "w": 400, "h": 520}, "z_order": 10},
    {"id": "pip-lr", "geometry": {"kind": "rect", "x": 1500, "y":  860, "w": 400, "h": 200}, "z_order": 10}
  ],
  "assignments": [
    {"source": "token_pole",     "surface": "pip-ul"},
    {"source": "reverie",        "surface": "pip-ur"},
    {"source": "album",          "surface": "pip-ll"},
    {"source": "stream_overlay", "surface": "pip-lr"}
  ]
}
