{
  "name": "Datamosh",
  "description": "P-frame block corruption",
  "transition_ms": 300,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.15,
        "contrast": 1.4,
        "saturation": 1.3
      }
    },
    "glitch_block": {
      "type": "glitch_block",
      "params": {
        "intensity": 0.8,
        "rgb_split": 0.6,
        "block_size": 8
      }
    },
    "stutter": {
      "type": "stutter",
      "params": {
        "freeze_chance": 0.1,
        "replay_frames": 2
      }
    },
    "chroma": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 5,
        "offset_y": 2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.15,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "glitch_block"
    ],
    [
      "glitch_block",
      "stutter"
    ],
    [
      "stutter",
      "chroma"
    ],
    [
      "chroma",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
