{
  "name": "Sculpture",
  "description": "Rutt-Etra wireframe terrain",
  "transition_ms": 500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.2,
        "contrast": 1.2,
        "saturation": 0.7
      }
    },
    "rutt_etra": {
      "type": "rutt_etra",
      "params": {
        "displacement": 40,
        "line_density": 5,
        "line_width": 3.0,
        "color_mode": 0.0
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.15,
        "radius": 12,
        "alpha": 0.4
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.2,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "rutt_etra"
    ],
    [
      "rutt_etra",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
