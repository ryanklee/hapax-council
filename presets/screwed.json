{
  "name": "Screwed",
  "description": "DJ Screw chopped temporal",
  "transition_ms": 500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.2,
        "saturation": 0.7,
        "contrast": 1.1,
        "sepia": 0.15
      }
    },
    "stutter": {
      "type": "stutter",
      "params": {
        "freeze_chance": 0.15,
        "replay_frames": 3
      }
    },
    "warp": {
      "type": "warp",
      "params": {
        "slice_count": 5,
        "slice_amplitude": 8,
        "pan_x": 3,
        "pan_y": 1
      }
    },
    "syrup": {
      "type": "syrup",
      "params": {
        "bottom_alpha": 0.35,
        "color_r": 0.15,
        "color_g": 0.05,
        "color_b": 0.2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    },
    "posterize": {
      "type": "posterize",
      "params": {
        "levels": 5,
        "gamma": 1.0
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "posterize"
    ],
    [
      "posterize",
      "stutter"
    ],
    [
      "stutter",
      "warp"
    ],
    [
      "warp",
      "syrup"
    ],
    [
      "syrup",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
