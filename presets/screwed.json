{
  "name": "Screwed",
  "description": "Heavy syrup",
  "transition_ms": 500,
  "nodes": {
    "warp": {
      "type": "warp",
      "params": {
        "slice_count": 10,
        "slice_amplitude": 3,
        "pan_x": 2,
        "pan_y": 1
      }
    },
    "stutter": {
      "type": "stutter",
      "params": {
        "freeze_chance": 0.2
      }
    },
    "trail": {
      "type": "trail",
      "params": {
        "fade": 0.015,
        "blend_mode": "screen",
        "opacity": 0.6
      }
    },
    "syrup": {
      "type": "syrup",
      "params": {
        "bottom_alpha": 0.4,
        "color_r": 0.15,
        "color_g": 0.05,
        "color_b": 0.2
      }
    },
    "scanlines": {
      "type": "scanlines",
      "params": {}
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "warp"
    ],
    [
      "warp",
      "stutter"
    ],
    [
      "stutter",
      "trail"
    ],
    [
      "trail",
      "syrup"
    ],
    [
      "syrup",
      "scanlines"
    ],
    [
      "scanlines",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}