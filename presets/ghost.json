{
  "name": "Ghost",
  "description": "Transparent echo",
  "transition_ms": 500,
  "nodes": {
    "trail": {
      "type": "trail",
      "params": {
        "fade": 0.06,
        "blend_mode": "lighter",
        "opacity": 0.5
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.4,
        "radius": 10.0,
        "alpha": 0.25
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "trail"
    ],
    [
      "trail",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
