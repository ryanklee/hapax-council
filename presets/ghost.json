{
  "name": "Ghost",
  "description": "Chronophotographic echo",
  "transition_ms": 500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.1,
        "contrast": 1.05,
        "saturation": 0.7
      }
    },
    "trail": {
      "type": "trail",
      "params": {
        "fade": 0.05,
        "blend_mode": "lighter",
        "opacity": 0.15,
        "drift_x": 0,
        "drift_y": 0
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.3,
        "radius": 10,
        "alpha": 0.2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    },
    "noise": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.15
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "trail"
    ],
    [
      "trail",
      "bloom"
    ],
    [
      "bloom",
      "noise"
    ],
    [
      "noise",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
