{
  "name": "Ghost",
  "description": "Transparent echo",
  "transition_ms": 500,
  "nodes": {
    "trail": {
      "type": "trail",
      "params": {
        "fade": 0.03,
        "blend_mode": "screen",
        "opacity": 0.6,
        "drift_x": 1,
        "drift_y": 0.5
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.2,
        "radius": 15,
        "alpha": 0.3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.5,
        "contrast": 1.2,
        "saturation": 0.7
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "trail"
    ],
    [
      "trail",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}