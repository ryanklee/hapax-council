{
  "name": "Neon",
  "description": "Synthwave glowing edges with cycling palette + audio-reactive cycle rate",
  "transition_ms": 500,
  "nodes": {
    "edge": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.03,
        "color_mode": 0.0
      }
    },
    "palette": {
      "type": "palette_remap",
      "params": {
        "palette_id": 0.0,
        "cycle_rate": 0.3,
        "n_bands": 12.0,
        "blend": 1.0
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.85,
        "contrast": 1.2,
        "saturation": 1.2
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.06,
        "radius": 20,
        "alpha": 0.6
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.2,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    [
      "@live",
      "edge"
    ],
    [
      "edge",
      "palette"
    ],
    [
      "palette",
      "colorgrade"
    ],
    [
      "colorgrade",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "palette",
      "param": "cycle_rate",
      "source": "audio_energy",
      "scale": 0.5,
      "offset": 0.3,
      "smoothing": 0.2
    }
  ]
}
