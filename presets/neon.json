{
  "name": "Neon",
  "description": "Synthwave glowing edges",
  "transition_ms": 500,
  "nodes": {
    "edge": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.03,
        "color_mode": 0.0
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.1,
        "contrast": 1.2,
        "saturation": 1.2
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.06,
        "radius": 20,
        "alpha": 0.6
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.2,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    [
      "@live",
      "edge"
    ],
    [
      "edge",
      "colorgrade"
    ],
    [
      "colorgrade",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "colorgrade",
      "param": "hue_rotate",
      "source": "time",
      "scale": 6.0,
      "offset": 0.0,
      "smoothing": 0.0
    }
  ],
  "layer_palettes": {}
}
