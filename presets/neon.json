{
  "name": "Neon",
  "description": "Synthwave glowing edges",
  "transition_ms": 500,
  "nodes": {
    "edge": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.03,
        "color_mode": 0.0
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 2.5,
        "saturation": 1.0,
        "contrast": 1.3,
        "hue_rotate": 3.0
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.02,
        "radius": 22,
        "alpha": 0.85
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.2,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    ["@live", "edge"],
    ["edge", "colorgrade"],
    ["colorgrade", "bloom"],
    ["bloom", "content_layer"],
    ["content_layer", "postprocess"],
    ["postprocess", "out"]
  ],
  "modulations": [
    {"node": "colorgrade", "param": "hue_rotate", "source": "time", "scale": 0.3, "offset": 0.0, "smoothing": 0.0}
  ],
  "layer_palettes": {}
}
