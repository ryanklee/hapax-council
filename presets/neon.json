{
  "name": "Neon",
  "description": "Synthwave glowing edges",
  "transition_ms": 500,
  "nodes": {
    "edge": {
      "type": "edge_detect",
      "params": {
        "threshold": 0.03,
        "color_mode": 1.0
      }
    },
    "chroma": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 6,
        "offset_y": 3
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 3.0,
        "saturation": 4.0,
        "contrast": 1.5
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.02,
        "radius": 18,
        "alpha": 0.7
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.2,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    ["@live", "edge"],
    ["edge", "chroma"],
    ["chroma", "colorgrade"],
    ["colorgrade", "bloom"],
    ["bloom", "content_layer"],
    ["content_layer", "postprocess"],
    ["postprocess", "out"]
  ],
  "modulations": [],
  "layer_palettes": {}
}
