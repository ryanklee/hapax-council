{
  "name": "Feedback",
  "description": "Deep recursion",
  "transition_ms": 500,
  "nodes": {
    "trail": {
      "type": "trail",
      "params": {
        "fade": 0.02,
        "blend_mode": "screen",
        "opacity": 0.7,
        "drift_x": 4,
        "drift_y": 3
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.15,
        "radius": 18,
        "alpha": 0.5
      }
    },
    "chroma": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 4,
        "offset_y": 2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.8,
        "contrast": 1.3,
        "saturation": 1.5
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "trail"
    ],
    [
      "trail",
      "bloom"
    ],
    [
      "bloom",
      "chroma"
    ],
    [
      "chroma",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "bloom",
      "param": "alpha",
      "source": "audio_beat",
      "scale": 0.2,
      "offset": 0.35,
      "smoothing": 0.6
    }
  ],
  "layer_palettes": {}
}