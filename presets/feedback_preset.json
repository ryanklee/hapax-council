{
  "name": "Feedback",
  "description": "Deep recursion",
  "transition_ms": 500,
  "nodes": {
    "trail": {
      "type": "trail",
      "params": {
        "fade": 0.03,
        "blend_mode": "screen",
        "opacity": 0.45,
        "drift_x": 3,
        "drift_y": 2
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.25,
        "radius": 16,
        "alpha": 0.45
      }
    },
    "chroma": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 5,
        "offset_y": 3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "trail"
    ],
    [
      "trail",
      "bloom"
    ],
    [
      "bloom",
      "chroma"
    ],
    [
      "chroma",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "bloom",
      "param": "alpha",
      "source": "audio_beat",
      "scale": 0.2,
      "offset": 0.35,
      "smoothing": 0.6
    }
  ],
  "layer_palettes": {}
}
