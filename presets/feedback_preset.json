{
  "name": "Feedback",
  "description": "Recursive video tunnel",
  "transition_ms": 500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.15,
        "contrast": 1.1,
        "saturation": 1.3
      }
    },
    "trail": {
      "type": "trail",
      "params": {
        "fade": 0.03,
        "blend_mode": "add",
        "opacity": 0.4,
        "drift_x": 8,
        "drift_y": 6
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.15,
        "radius": 16,
        "alpha": 0.4
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.25,
        "sediment_strength": 0.08
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "trail"
    ],
    [
      "trail",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "bloom",
      "param": "alpha",
      "source": "audio_beat",
      "scale": 0.3,
      "offset": 0.0,
      "smoothing": 0.5
    }
  ],
  "layer_palettes": {}
}
