{
  "name": "Trails",
  "description": "Heavy additive motion",
  "transition_ms": 500,
  "nodes": {
    "trail": {
      "type": "trail",
      "params": {
        "fade": 0.06,
        "blend_mode": "screen",
        "opacity": 0.4,
        "drift_x": 2,
        "drift_y": 1
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.35,
        "radius": 12.0,
        "alpha": 0.35
      }
    },
    "grain": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.04
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "trail"
    ],
    [
      "trail",
      "bloom"
    ],
    [
      "bloom",
      "grain"
    ],
    [
      "grain",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "trail",
      "param": "opacity",
      "source": "audio_rms",
      "scale": 0.3,
      "offset": 0.3,
      "smoothing": 0.85
    },
    {
      "node": "bloom",
      "param": "alpha",
      "source": "audio_beat",
      "scale": 0.2,
      "offset": 0.25,
      "smoothing": 0.7
    }
  ],
  "layer_palettes": {}
}
