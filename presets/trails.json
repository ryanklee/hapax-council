{
  "name": "Trails",
  "description": "Additive motion persistence",
  "transition_ms": 500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.1,
        "saturation": 1.2
      }
    },
    "trail": {
      "type": "trail",
      "params": {
        "fade": 0.03,
        "blend_mode": "lighter",
        "opacity": 0.45,
        "drift_x": 5,
        "drift_y": 3
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.25,
        "radius": 12,
        "alpha": 0.35
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.25,
        "sediment_strength": 0.08
      }
    },
    "noise": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "trail"
    ],
    [
      "trail",
      "bloom"
    ],
    [
      "bloom",
      "noise"
    ],
    [
      "noise",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "trail",
      "param": "opacity",
      "source": "audio_rms",
      "scale": 0.3,
      "offset": 0.0,
      "smoothing": 0.7
    }
  ],
  "layer_palettes": {}
}
