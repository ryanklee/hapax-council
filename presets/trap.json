{
  "name": "Trap",
  "description": "Aggressive layered glitch",
  "transition_ms": 200,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "saturation": 1.4,
        "brightness": 1.2,
        "contrast": 1.5
      }
    },
    "glitch_block": {
      "type": "glitch_block",
      "params": {
        "intensity": 0.7,
        "rgb_split": 0.6,
        "block_size": 16
      }
    },
    "chroma": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 8,
        "offset_y": 4
      }
    },
    "trail": {
      "type": "trail",
      "params": {
        "fade": 0.08,
        "blend_mode": "lighter",
        "opacity": 0.3
      }
    },
    "noise": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.12
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.2,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    ["@live", "colorgrade"],
    ["colorgrade", "glitch_block"],
    ["glitch_block", "chroma"],
    ["chroma", "trail"],
    ["trail", "noise"],
    ["noise", "content_layer"],
    ["content_layer", "postprocess"],
    ["postprocess", "out"]
  ],
  "modulations": [],
  "layer_palettes": {}
}
