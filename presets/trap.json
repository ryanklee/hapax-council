{
  "name": "Trap",
  "description": "Aggressive layered glitch",
  "transition_ms": 200,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.2,
        "saturation": 1.5,
        "contrast": 1.3
      }
    },
    "glitch_block": {
      "type": "glitch_block",
      "params": {
        "intensity": 0.85,
        "rgb_split": 0.7,
        "block_size": 16
      }
    },
    "chroma": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 12,
        "offset_y": 6
      }
    },
    "noise": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.15
      }
    },
    "scanlines": {
      "type": "scanlines",
      "params": {
        "opacity": 0.1
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.15,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "glitch_block"
    ],
    [
      "glitch_block",
      "chroma"
    ],
    [
      "chroma",
      "noise"
    ],
    [
      "noise",
      "scanlines"
    ],
    [
      "scanlines",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
