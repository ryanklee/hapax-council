{
  "name": "Fisheye Pulse",
  "description": "Fisheye pulse",
  "transition_ms": 500,
  "nodes": {
    "fisheye": {
      "type": "fisheye",
      "params": {
        "strength": 0.6,
        "zoom": 0.4
      }
    },
    "chroma": {
      "type": "chromatic_aberration",
      "params": {
        "offset_x": 10,
        "offset_y": 5
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.0,
        "sediment_strength": 0.1
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.2,
        "radius": 12,
        "alpha": 0.35
      }
    }
  },
  "edges": [
    [
      "@live",
      "fisheye"
    ],
    [
      "fisheye",
      "bloom"
    ],
    [
      "bloom",
      "chroma"
    ],
    [
      "chroma",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "fisheye",
      "param": "strength",
      "source": "audio_beat",
      "scale": 0.5,
      "offset": 0.3,
      "smoothing": 0.7
    }
  ],
  "layer_palettes": {}
}
