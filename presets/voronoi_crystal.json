{
  "name": "Voronoi Crystal",
  "description": "Voronoi crystal",
  "transition_ms": 500,
  "nodes": {
    "voronoi": {
      "type": "voronoi_overlay",
      "params": {
        "cell_count": 120,
        "edge_width": 0.04,
        "animation_speed": 0.8
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.8,
        "contrast": 1.4,
        "saturation": 1.5
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.5,
        "radius": 6,
        "alpha": 0.2
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "voronoi"
    ],
    [
      "voronoi",
      "colorgrade"
    ],
    [
      "colorgrade",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}