{
  "name": "Dithered Retro",
  "description": "Dithered retro",
  "transition_ms": 500,
  "nodes": {
    "posterize": {
      "type": "posterize",
      "params": {
        "levels": 4,
        "gamma": 1.2
      }
    },
    "dither": {
      "type": "dither",
      "params": {
        "color_levels": 4
      }
    },
    "scanlines": {
      "type": "scanlines",
      "params": {
        "opacity": 0.1
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.25
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "posterize"
    ],
    [
      "posterize",
      "dither"
    ],
    [
      "dither",
      "scanlines"
    ],
    [
      "scanlines",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
