{
  "name": "Clean",
  "description": "Minimal processing",
  "transition_ms": 300,
  "nodes": {
    "color": {
      "type": "colorgrade",
      "params": {
        "saturation": 1.05,
        "brightness": 1.02,
        "contrast": 1.05
      }
    },
    "vig": {
      "type": "vignette",
      "params": {
        "strength": 0.15,
        "radius": 0.8,
        "softness": 0.3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "color"
    ],
    [
      "color",
      "vig"
    ],
    [
      "vig",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
