{
  "name": "Kaleidoscope Dream",
  "description": "Kaleidoscope dream",
  "transition_ms": 500,
  "nodes": {
    "kaleidoscope": {
      "type": "kaleidoscope",
      "params": {
        "segments": 6,
        "rotation": 0
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.5,
        "contrast": 1.2,
        "saturation": 1.5
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.35,
        "radius": 10,
        "alpha": 0.3
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "kaleidoscope"
    ],
    [
      "kaleidoscope",
      "colorgrade"
    ],
    [
      "colorgrade",
      "bloom"
    ],
    [
      "bloom",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [
    {
      "node": "kaleidoscope",
      "param": "rotation",
      "source": "audio_rms",
      "scale": 180,
      "offset": 0,
      "smoothing": 0.9
    }
  ],
  "layer_palettes": {}
}