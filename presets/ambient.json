{
  "name": "Ambient",
  "description": "Dim atmospheric",
  "transition_ms": 500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 0.5,
        "saturation": 0.4,
        "contrast": 0.8
      }
    },
    "drift": {
      "type": "drift",
      "params": {
        "speed": 0.2,
        "amplitude": 5,
        "frequency": 1.0
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.3,
        "radius": 12,
        "alpha": 0.2
      }
    },
    "vignette": {
      "type": "vignette",
      "params": {
        "strength": 0.5
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "drift"
    ],
    [
      "drift",
      "bloom"
    ],
    [
      "bloom",
      "vignette"
    ],
    [
      "vignette",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
