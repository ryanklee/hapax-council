{
  "name": "Night Vision",
  "description": "Green phosphor",
  "transition_ms": 500,
  "nodes": {
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "saturation": 0.3,
        "brightness": 1.2,
        "hue_rotate": 120
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.3,
        "radius": 8,
        "alpha": 0.3
      }
    },
    "scanlines": {
      "type": "scanlines",
      "params": {
        "opacity": 0.15
      }
    },
    "noise": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.08,
        "animated": true
      }
    },
    "mask": {
      "type": "circular_mask",
      "params": {
        "radius": 0.42
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "colorgrade"
    ],
    [
      "colorgrade",
      "bloom"
    ],
    [
      "bloom",
      "scanlines"
    ],
    [
      "scanlines",
      "noise"
    ],
    [
      "noise",
      "mask"
    ],
    [
      "mask",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
