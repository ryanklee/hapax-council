{
  "name": "Night Vision",
  "description": "Green phosphor",
  "transition_ms": 500,
  "nodes": {
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.2,
        "radius": 12,
        "alpha": 0.4
      }
    },
    "scanlines": {
      "type": "scanlines",
      "params": {
        "opacity": 0.15
      }
    },
    "noise": {
      "type": "noise_overlay",
      "params": {
        "intensity": 0.08,
        "animated": true
      }
    },
    "mask": {
      "type": "circular_mask",
      "params": {
        "radius": 0.38,
        "softness": 0.08
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    },
    "nvtint": {
      "type": "nightvision_tint",
      "params": {
        "green_intensity": 0.85,
        "brightness": 2.5,
        "contrast": 1.5
      }
    }
  },
  "edges": [
    [
      "@live",
      "nvtint"
    ],
    [
      "nvtint",
      "bloom"
    ],
    [
      "bloom",
      "scanlines"
    ],
    [
      "scanlines",
      "noise"
    ],
    [
      "noise",
      "mask"
    ],
    [
      "mask",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}