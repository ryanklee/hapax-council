{
  "name": "Pixel Sorting",
  "description": "Pixel sorting",
  "transition_ms": 500,
  "nodes": {
    "pixsort": {
      "type": "pixsort",
      "params": {
        "threshold": 0.3,
        "segment_length": 100
      }
    },
    "scanlines": {
      "type": "scanlines",
      "params": {
        "opacity": 0.08
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.1
      }
    }
  },
  "edges": [
    [
      "@live",
      "pixsort"
    ],
    [
      "pixsort",
      "scanlines"
    ],
    [
      "scanlines",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
