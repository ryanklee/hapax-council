{
  "name": "Slit-scan",
  "description": "Temporal slit-scan \u2014 each column represents a different moment in time. Douglas Trumbull Stargate reference.",
  "transition_ms": 500,
  "nodes": {
    "slitscan": {
      "type": "slitscan",
      "params": {
        "delay": 0.4,
        "direction": 0
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.2,
        "contrast": 1.2,
        "saturation": 1.0
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.08
      }
    }
  },
  "edges": [
    [
      "@live",
      "slitscan"
    ],
    [
      "slitscan",
      "colorgrade"
    ],
    [
      "colorgrade",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
