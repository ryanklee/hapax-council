{
  "name": "Slit-scan",
  "description": "Temporal slit-scan — each column represents a different moment in time. Douglas Trumbull Stargate reference.",
  "transition_ms": 500,
  "nodes": {
    "slitscan": {
      "type": "slitscan",
      "params": {
        "direction": 0,
        "speed": 1.5
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "saturation": 1.15,
        "contrast": 1.1
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.3,
        "sediment_strength": 0.08
      }
    }
  },
  "edges": [
    ["@live", "slitscan"],
    ["slitscan", "colorgrade"],
    ["colorgrade", "content_layer"],
    ["content_layer", "postprocess"],
    ["postprocess", "out"]
  ],
  "modulations": [],
  "layer_palettes": {}
}
