{
  "name": "Motion Detection",
  "description": "Frame differencing — only motion is visible. Double-ghost contour with leading and trailing edges. Daniel Rozin Mechanical Mirrors reference.",
  "transition_ms": 500,
  "nodes": {
    "diff": {
      "type": "diff",
      "params": {
        "threshold": 0.06,
        "color_mode": 0
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "contrast": 1.8,
        "brightness": 1.5,
        "saturation": 0.3
      }
    },
    "bloom": {
      "type": "bloom",
      "params": {
        "threshold": 0.2,
        "radius": 6,
        "alpha": 0.25
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.35,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    ["@live", "diff"],
    ["diff", "colorgrade"],
    ["colorgrade", "bloom"],
    ["bloom", "content_layer"],
    ["content_layer", "postprocess"],
    ["postprocess", "out"]
  ],
  "modulations": [],
  "layer_palettes": {}
}
