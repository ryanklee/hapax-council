{
  "name": "Thermal IR",
  "description": "FLIR iron bow thermography",
  "transition_ms": 500,
  "nodes": {
    "thermal": {
      "type": "thermal",
      "params": {
        "edge_glow": 0.6,
        "color_mode": 1
      }
    },
    "colorgrade": {
      "type": "colorgrade",
      "params": {
        "brightness": 1.0,
        "contrast": 1.0,
        "saturation": 1.0
      }
    },
    "out": {
      "type": "output",
      "params": {}
    },
    "content_layer": {
      "type": "content_layer",
      "params": {}
    },
    "postprocess": {
      "type": "postprocess",
      "params": {
        "vignette_strength": 0.15,
        "sediment_strength": 0.05
      }
    }
  },
  "edges": [
    [
      "@live",
      "thermal"
    ],
    [
      "thermal",
      "colorgrade"
    ],
    [
      "colorgrade",
      "content_layer"
    ],
    [
      "content_layer",
      "postprocess"
    ],
    [
      "postprocess",
      "out"
    ]
  ],
  "modulations": [],
  "layer_palettes": {}
}
