#!/usr/bin/env bash
set -euo pipefail

# DEPRECATED: Use hapax-working-mode instead.
# This shim maps devâ†’rnd, prodâ†’research for backward compatibility.

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"

if [[ $# -eq 0 ]]; then
    "$SCRIPT_DIR/hapax-working-mode"
    exit 0
fi

echo "WARNING: hapax-mode is deprecated. Use hapax-working-mode [research|rnd] instead." >&2

case "$1" in
    dev)  "$SCRIPT_DIR/hapax-working-mode" rnd ;;
    prod) "$SCRIPT_DIR/hapax-working-mode" research ;;
    *)    echo "Usage: hapax-working-mode [research|rnd]" >&2; exit 1 ;;
esac
