#!/usr/bin/env python3
"""Audit audio-router state surfaces (Phase A4 of evilpet-s4-dynamic-dual-processor-plan).

Checks presence + freshness + JSON validity of the four state surfaces
the dynamic router agent (Phase B3) will depend on:

  - /dev/shm/hapax-stimmung/current.json         (stance + 6-dim vector)
  - /dev/shm/hapax-voice-tier-current.json       (active voice tier)
  - /dev/shm/hapax-programme/current.json        (active programme role + opt-ins)
  - /dev/shm/hapax-compositor/evil-pet-state.json (MIDI ownership ledger)

Exits 0 if all surfaces healthy. Exits 1 with a report of stale or
missing surfaces. Per-surface staleness budgets follow the spec:
stimmung 30s, voice-tier 60s, programme 300s, evil-pet-state 15s.

Usage:
    hapax-audio-state-audit [--json]

The --json flag emits a machine-readable report for consumption by
health_monitor or other tooling.
"""

from __future__ import annotations

import argparse
import json
import sys
import time
from pathlib import Path

SURFACES: list[tuple[str, float, str]] = [
    ("/dev/shm/hapax-stimmung/current.json", 30.0, "stimmung stance + 6-dim vector"),
    ("/dev/shm/hapax-voice-tier-current.json", 60.0, "active voice tier"),
    (
        "/dev/shm/hapax-programme/current.json",
        300.0,
        "active programme role + monetization opt-ins",
    ),
    ("/dev/shm/hapax-compositor/evil-pet-state.json", 15.0, "Evil Pet MIDI ownership ledger"),
]


def audit() -> tuple[list[dict], int]:
    now = time.time()
    results: list[dict] = []
    exit_code = 0
    for path_s, budget_s, description in SURFACES:
        path = Path(path_s)
        entry: dict = {
            "path": path_s,
            "description": description,
            "budget_s": budget_s,
            "status": "healthy",
            "issues": [],
        }
        if not path.exists():
            entry["status"] = "missing"
            entry["issues"].append("file does not exist")
            exit_code = 1
        else:
            try:
                age = now - path.stat().st_mtime
                entry["age_s"] = round(age, 1)
                if age > budget_s:
                    entry["status"] = "stale"
                    entry["issues"].append(f"age {age:.1f}s exceeds budget {budget_s}s")
                    exit_code = 1
            except OSError as e:
                entry["status"] = "unreadable"
                entry["issues"].append(f"stat failed: {e}")
                exit_code = 1
                results.append(entry)
                continue
            try:
                json.loads(path.read_text())
            except json.JSONDecodeError as e:
                entry["status"] = "invalid_json"
                entry["issues"].append(f"not valid JSON: {e}")
                exit_code = 1
            except OSError as e:
                entry["status"] = "unreadable"
                entry["issues"].append(f"read failed: {e}")
                exit_code = 1
        results.append(entry)
    return results, exit_code


def format_human(results: list[dict]) -> str:
    lines = []
    healthy = sum(1 for r in results if r["status"] == "healthy")
    lines.append(f"Audio router state surface audit — {healthy}/{len(results)} healthy")
    lines.append("")
    for r in results:
        badge = {
            "healthy": "OK   ",
            "stale": "STALE",
            "missing": "MISS ",
            "invalid_json": "JSON ",
            "unreadable": "RERR ",
        }.get(r["status"], "?????")
        age = r.get("age_s")
        age_suffix = f" (age={age}s)" if age is not None else ""
        lines.append(f"  [{badge}] {r['path']}{age_suffix}")
        lines.append(f"          {r['description']} (budget={r['budget_s']}s)")
        for issue in r["issues"]:
            lines.append(f"          ! {issue}")
    return "\n".join(lines)


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__.splitlines()[0])
    parser.add_argument("--json", action="store_true", help="emit machine-readable JSON report")
    args = parser.parse_args()
    results, exit_code = audit()
    if args.json:
        print(json.dumps({"exit_code": exit_code, "surfaces": results}, indent=2))
    else:
        print(format_human(results))
    return exit_code


if __name__ == "__main__":
    sys.exit(main())
