[Unit]
Description=Ambient audio processor — classify, transcribe, and index for RAG
After=network.target
OnFailure=notify-failure@%n.service

[Service]
Type=oneshot
ExecStart=/home/operator/.local/bin/uv run --directory /home/operator/projects/hapax-council python -m agents.audio_processor --process
Environment=PATH=/home/operator/.local/bin:/home/operator/.cargo/bin:/usr/local/bin:/usr/bin:/bin
Environment=HOME=/home/hapax
Environment=GNUPGHOME=/home/operator/.gnupg
Environment=PASSWORD_STORE_DIR=/home/operator/.password-store
MemoryMax=8G
CPUQuota=80%
StandardOutput=journal
StandardError=journal
SyslogIdentifier=audio-processor
