[Unit]
Description=LLM Stack Backup
After=network-online.target
OnFailure=notify-failure@%n.service

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'eval "$(<$HOME/projects/ai-agents/.envrc)" && exec /home/hapax/Scripts/setup/llm-stack-scripts/llm-stack/scripts/backup.sh'
WorkingDirectory=/home/hapax/llm-stack
Environment=PATH=/home/hapax/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=HOME=/home/hapax
Environment=GNUPGHOME=/home/hapax/.gnupg
Environment=PASSWORD_STORE_DIR=/home/hapax/.password-store
MemoryMax=1G
CPUQuota=50%
SyslogIdentifier=llm-backup
