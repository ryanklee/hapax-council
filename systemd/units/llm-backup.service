[Unit]
Description=LLM Stack Backup
After=network-online.target
OnFailure=notify-failure@%n.service

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'set -a && source $HOME/projects/hapax-council/.envrc && set +a && exec /home/operator/Scripts/setup/llm-stack-scripts/llm-stack/scripts/backup.sh'
WorkingDirectory=/home/operator/llm-stack
Environment=PATH=/home/operator/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=HOME=/home/hapax
Environment=GNUPGHOME=/home/operator/.gnupg
Environment=PASSWORD_STORE_DIR=/home/operator/.password-store
MemoryMax=1G
CPUQuota=50%
SyslogIdentifier=llm-backup
