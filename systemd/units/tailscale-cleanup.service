[Unit]
Description=Tailscale stale device cleanup — remove devices offline >90 days

[Service]
Type=oneshot
ExecStart=/home/hapax/projects/hapax-council/scripts/tailscale-cleanup.sh 90
Environment=PATH=/home/hapax/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=HOME=/home/hapax
Environment=GNUPGHOME=/home/hapax/.gnupg
Environment=PASSWORD_STORE_DIR=/home/hapax/.password-store
StandardOutput=journal
StandardError=journal
SyslogIdentifier=tailscale-cleanup
