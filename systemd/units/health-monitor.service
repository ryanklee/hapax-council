[Unit]
Description=LLM Stack Health Monitor (auto-fix + notify)
After=network.target
OnFailure=notify-failure@%n.service

[Service]
Type=oneshot
SuccessExitStatus=1
ExecStart=/home/hapax/.local/bin/health-watchdog
Environment=PATH=/home/hapax/.local/bin:/home/hapax/.cargo/bin:/usr/local/bin:/usr/bin:/bin
Environment=HOME=/home/hapax
Environment=GNUPGHOME=/home/hapax/.gnupg
Environment=PASSWORD_STORE_DIR=/home/hapax/.password-store
StandardOutput=journal
StandardError=journal
SyslogIdentifier=health-monitor
MemoryMax=512M
CPUQuota=30%
