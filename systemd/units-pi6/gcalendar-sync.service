[Unit]
Description=Google Calendar sync (Pi6 offload)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/home/hapax/projects/hapax-council
Environment=PATH=/home/hapax/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=GNUPGHOME=/home/hapax/.gnupg
Environment=PASSWORD_STORE_DIR=/home/hapax/.password-store
Environment=PYTHONPATH=/home/hapax/projects/hapax-council
ExecStart=/home/hapax/projects/hapax-council/.venv-sync/bin/python -m agents.gcalendar_sync --auto
MemoryMax=512M
CPUQuota=50%
StandardOutput=journal
StandardError=journal
SyslogIdentifier=gcalendar-sync

[Install]
WantedBy=default.target
