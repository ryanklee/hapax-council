#!/usr/bin/env bash
set -euo pipefail

# Knowledge base maintenance — prune stale sources and deduplicate vectors
cd /home/hapax/projects/hapax-council

# Load credentials from pass store (systemd sets PASSWORD_STORE_DIR + GNUPGHOME)
export LITELLM_API_KEY=$(pass show litellm/master-key 2>/dev/null || echo "changeme")
export LANGFUSE_PUBLIC_KEY=$(pass show langfuse/public-key 2>/dev/null || true)
export LANGFUSE_SECRET_KEY=$(pass show langfuse/secret-key 2>/dev/null || true)

UV=/home/hapax/.local/bin/uv
REPORT=$($UV run python -m agents.knowledge_maint --apply --save --json 2>/dev/null)

# Notify via shared.notify if work was done (pass JSON via stdin)
echo "$REPORT" | $UV run python -c "
import sys, json
from shared.notify import send_notification
r = json.load(sys.stdin)
pruned = r.get('total_pruned', 0)
merged = r.get('total_merged', 0)
warnings = len(r.get('warnings', []))
total = pruned + merged + warnings
if total > 0:
    body = f'Pruned {pruned} stale, merged {merged} duplicates'
    if warnings > 0:
        body += f', {warnings} warning(s)'
    send_notification('Knowledge Maintenance', body, tags=['broom'])
" 2>/dev/null || true

# Append to history
echo "$REPORT" >> /home/hapax/projects/hapax-council/profiles/knowledge-maint-history.jsonl 2>/dev/null || true
