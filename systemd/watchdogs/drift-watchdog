#!/usr/bin/env bash
# drift-watchdog — Scheduled drift reconciliation with notification.
# Runs via systemd timer. Detects drift, auto-fixes what it can, escalates the rest.
set -euo pipefail

cd /home/hapax/projects/hapax-council

# Load credentials from pass store (systemd sets PASSWORD_STORE_DIR + GNUPGHOME)
export LITELLM_API_KEY=$(pass show litellm/master-key 2>/dev/null || echo "changeme")
export LANGFUSE_PUBLIC_KEY=$(pass show langfuse/public-key 2>/dev/null || true)
export LANGFUSE_SECRET_KEY=$(pass show langfuse/secret-key 2>/dev/null || true)

UV=/home/hapax/.local/bin/uv

# Run drift reconciliation (detect → auto-fix → escalate → save report + history)
# The --reconcile mode handles: report saving, history appending, notifications, git commits
$UV run python -m agents.drift_detector --reconcile --json 2>/dev/null || {
    $UV run python -c "
from shared.notify import send_notification
send_notification('Drift Reconciler Failed', 'Could not run drift reconciliation', priority='urgent', tags=['skull'])
" 2>/dev/null || true
    exit 1
}
