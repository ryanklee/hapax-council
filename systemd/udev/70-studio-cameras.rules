# Studio camera udev rules — Phases 1 and 3 of the camera 24/7 resilience epic.
# See docs/superpowers/plans/2026-04-12-camera-247-resilience-epic.md
#
# Phase 1: disable USB autosuspend for studio cameras (BRIO 046d:085e and
# C920 046d:08e5). USB autosuspend is a documented contributor to webcam
# disappearance in 24/7 deployments.
#
# Phase 3: on add of a video4linux capture device backed by a studio camera,
# trigger studio-camera-reconfigure@<kernel-name>.service via systemd-udev
# integration to re-apply v4l2-ctl settings before the compositor re-opens
# the device.

# --- Phase 1: USB autosuspend off ---

# BRIO 4K (046d:085e)
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="046d", ATTR{idProduct}=="085e", ATTR{power/control}="on"

# C920 (046d:08e5)
ACTION=="add", SUBSYSTEM=="usb", ATTR{idVendor}=="046d", ATTR{idProduct}=="08e5", ATTR{power/control}="on"

# --- Phase 3: reconfigure on add ---
# TAG+="systemd" is required so systemd sees the device unit. SYSTEMD_USER_WANTS
# wires a user-scope template unit; %k is the kernel device name (e.g. video0).

ACTION=="add", SUBSYSTEM=="video4linux", ENV{ID_V4L_CAPABILITIES}==":capture:", \
    ATTRS{idVendor}=="046d", ATTRS{idProduct}=="085e", \
    TAG+="systemd", ENV{SYSTEMD_USER_WANTS}+="studio-camera-reconfigure@%k.service"

ACTION=="add", SUBSYSTEM=="video4linux", ENV{ID_V4L_CAPABILITIES}==":capture:", \
    ATTRS{idVendor}=="046d", ATTRS{idProduct}=="08e5", \
    TAG+="systemd", ENV{SYSTEMD_USER_WANTS}+="studio-camera-reconfigure@%k.service"
